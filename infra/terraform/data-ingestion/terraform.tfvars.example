# Copy to terraform.tfvars and fill in real values.
# Most values come from existing root module outputs / resource attributes.
#
# To wire this module into the root stack, add to infra/terraform/main.tf:
#
#   module "data_ingestion" {
#     source                     = "./data-ingestion"
#     name                       = var.name
#     region                     = var.region
#     ecs_cluster_arn            = aws_ecs_cluster.this.arn
#     ecs_cluster_name           = aws_ecs_cluster.this.name
#     private_subnet_ids         = var.private_subnet_ids
#     task_security_group_id     = aws_security_group.ecs_tasks.id
#     ecs_execution_role_arn     = aws_iam_role.task_execution.arn
#     ecs_task_role_arn          = aws_iam_role.task_role.arn
#     events_invoke_ecs_role_arn = aws_iam_role.eventbridge_ecs.arn
#     container_image            = var.image_data_ingestion
#     db_dsn                     = "postgresql://${var.db_username}:${var.db_password}@${aws_db_instance.pg.address}:5432/${var.db_name}?sslmode=require"
#     tt_app_key                 = var.tt_app_key
#     tt_app_secret              = var.tt_app_secret
#     s3_bucket                  = aws_s3_bucket.uploads.bucket
#   }
#
#   # New variables to add to infra/terraform/variables.tf:
#   variable "image_data_ingestion" { type = string }
#   variable "tt_app_key"           { type = string; sensitive = true }
#   variable "tt_app_secret"        { type = string; sensitive = true }
#
# When running this module standalone (not from root), set values below:

name                       = "bess-platform"
region                     = "ap-southeast-1"
ecs_cluster_arn            = "arn:aws:ecs:ap-southeast-1:123456789012:cluster/bess-platform-cluster"
ecs_cluster_name           = "bess-platform-cluster"
private_subnet_ids         = ["subnet-aaa111", "subnet-bbb222"]
task_security_group_id     = "sg-xxxxxxxx"  # aws_security_group.ecs_tasks.id from root
ecs_execution_role_arn     = "arn:aws:iam::123456789012:role/bess-platform-task-exec"
ecs_task_role_arn          = "arn:aws:iam::123456789012:role/bess-platform-task-role"
events_invoke_ecs_role_arn = "arn:aws:iam::123456789012:role/bess-platform-eventbridge-ecs"
container_image            = "123456789012.dkr.ecr.ap-southeast-1.amazonaws.com/bess-data-ingestion:latest"
db_dsn                     = "postgresql://postgres:CHANGE_ME@bess-platform-pg.xxxx.ap-southeast-1.rds.amazonaws.com:5432/marketdata?sslmode=require"
tt_app_key                 = "CHANGE_ME"
tt_app_secret              = "CHANGE_ME"
lingfeng_base_url          = ""   # leave empty until portal URL is confirmed
lingfeng_username          = ""
lingfeng_password          = ""
lingfeng_province_list     = ""
s3_bucket                  = "bess-platform-uploads"  # aws_s3_bucket.uploads.bucket from root
