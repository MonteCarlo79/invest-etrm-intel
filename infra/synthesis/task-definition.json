{
  "family": "bess-synthesis",
  "taskRoleArn": "arn:aws:iam::319383842493:role/bess-platform-task-role",
  "executionRoleArn": "arn:aws:iam::319383842493:role/bess-platform-task-exec",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "containerDefinitions": [
    {
      "name": "synthesis",
      "image": "319383842493.dkr.ecr.ap-southeast-1.amazonaws.com/bess-synthesis:latest",
      "essential": true,
      "environment": [
        { "name": "PYTHONPATH",        "value": "/app" },
        { "name": "PYTHONUNBUFFERED",  "value": "1"    }
      ],
      "command": [
        "python", "scripts/run_synthesis_pipeline.py",
        "--phase", "1",
        "--app", "shared",
        "--workers", "1"
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/bess-platform",
          "awslogs-region":        "ap-southeast-1",
          "awslogs-stream-prefix": "synthesis"
        }
      }
    }
  ]
}
